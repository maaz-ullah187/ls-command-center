# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Supabase is the data warehouse. Create a project at https://supabase.com,
# then run the SQL files in supabase/migrations/ in order.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth — protects the whole dashboard behind a single shared password.
DASHBOARD_AUTH_PASS=
DASHBOARD_AUTH_SECRET=

# Email shown as the "edited_by" value when an operator inline-edits a number.
OPERATOR_EMAIL=operator@example.com

# Public site URL (used for outbound webhooks and Slack deep links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── OPTIONAL: AI / SCORING ──────────────────────────────────────────────────
# Anthropic Claude — powers the AI lead scoring and the chat panel.
ANTHROPIC_API_KEY=

# ─── OPTIONAL: ADS ───────────────────────────────────────────────────────────
# Meta (Facebook/Instagram) Ads. Use a system-user token for stability.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
NEXT_PUBLIC_META_AD_ACCOUNT_ID=
# Optional: route Meta API traffic through a proxy you control (e.g. a Tailscale
# Flask app on a fixed home IP) to avoid account flagging.
META_PROXY_URL=
META_PROXY_API_KEY=

# ─── OPTIONAL: CRM (GoHighLevel) ─────────────────────────────────────────────
# Use a Private Integration Token (pit-...) scoped to one sub-account.
GHL_API_KEY=
GHL_LOCATION_ID=
NEXT_PUBLIC_GHL_LOCATION_ID=
# Custom-field ID containing the multi-line application/qualification answers.
GHL_QUAL_FIELD_ID=

# ─── OPTIONAL: APPLICATIONS (Typeform) ───────────────────────────────────────
TYPEFORM_TOKEN=

# ─── OPTIONAL: BOOKINGS (Calendly) ───────────────────────────────────────────
CALENDLY_TOKEN=
CALENDLY_ORG_ID=
# Or set the full URI directly:
CALENDLY_ORG_URI=

# ─── OPTIONAL: PAYMENTS ──────────────────────────────────────────────────────
WHOP_API_KEY=
FANBASIS_API_KEY=
STRIPE_SECRET_KEY=
MERCURY_API_KEY=

# ─── OPTIONAL: CALL RECORDINGS ───────────────────────────────────────────────
# Grain (primary, workspace-wide) and Fathom (fallback, personal).
GRAIN_API_KEY=
FATHOM_API_KEY=

# ─── OPTIONAL: SLACK ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Channels the sync workers read from
SLACK_CHANNEL_EODS=                # closer EODs (#sales-rep-eods)
SLACK_CHANNEL_NEW_CLIENTS=         # new client signed (#new-clients)
SLACK_CHANNEL_PAYMENT_NOTIS=       # payment success/failed (#payment-notifications)
SLACK_CHANNEL_DEMO_CALL_NOTES=     # post-call notes
SLACK_REVIEW_QUEUE_CHANNEL=        # review-queue surface
# Channels the dashboard posts to
SLACK_CHANNEL_MARKETING_MGR=
SLACK_CHANNEL_SALES_MGR=
SLACK_CHANNEL_CONTENT_MGR=
SLACK_NOTIFY_MARKETING_MANAGER=
SLACK_NOTIFY_SALES_MANAGER=
SLACK_NOTIFY_CONTENT_MANAGER=
# Optional separate ops bot
SLACK_OPS_BOT_TOKEN=
SLACK_OPS_CHANNEL=
SLACK_OPS_SIGNING_SECRET=
# Comma-separated lowercase emails of internal team — used to exclude
# internal-only Grain calls from the sales-call dataset.
TEAM_EMAILS=
# Comma-separated lowercase first names of team — used by Grain title parsing.
TEAM_FIRST_NAMES=

# ─── OPTIONAL: CONTENT (YouTube / IG / X / LinkedIn) ─────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
# If you embed redirect links in YouTube descriptions (e.g. r.example.com/SLUG)
# set the host here so the mapper can pull click-through stats.
YOUTUBE_REDIRECT_DOMAIN=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
MANYCHAT_API_KEY=

TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=
TWITTER_USER_ID=

# ─── OPTIONAL: CLIENT TRACKING (Monday.com) ──────────────────────────────────
MONDAY_API_KEY=
MONDAY_BOARD_PROGRAM_A=
MONDAY_BOARD_PROGRAM_B=
MONDAY_BOARD_PROGRAM_C=

# ─── OPTIONAL: GOOGLE SHEETS (CSV import fallback) ───────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
CLIENT_LEDGER_CSV_URL=

# ─── OPTIONAL: OUTBOUND WEBHOOKS ─────────────────────────────────────────────
# Set these to URLs on your attribution platform (e.g. tracking domain) so
# call-showed / qualified-showed / client-closed events get fired outbound.
WEBHOOK_CALL_SHOWED_URL=
WEBHOOK_QUALIFIED_SHOWED_URL=
WEBHOOK_CLIENT_CLOSED_URL=

# ─── OPTIONAL: ATTRIBUTION (Trakyo) ──────────────────────────────────────────
TRAKYO_API_KEY=
